## 4. Testing Async Code

### Async Operations
```typescript
it('should handle API errors', async () => {
  mockedAxios.get.mockRejectedValue(new Error('Network error'));
  await expect(fetchLaunches()).rejects.toThrow('Network error');
});

it('should poll and store launches', async () => {
  mockedAxios.get.mockResolvedValue({ data: { content: [mockLaunch] } });
  await pollReportPortal();
  expect(store.upsertLaunch).toHaveBeenCalledWith(expect.objectContaining({
    rpId: mockLaunch.id,
  }));
});
```

---

## 5. Testing Express Routes

### Route Handler Tests
```typescript
import request from 'supertest';
import app from '../api';

describe('GET /api/launches', () => {
  it('should return launches', async () => {
    const res = await request(app).get('/api/launches');
    expect(res.status).toBe(200);
    expect(res.body).toBeInstanceOf(Array);
  });

  it('should return 500 on database error', async () => {
    jest.spyOn(store, 'getLaunches').mockImplementation(() => {
      throw new Error('DB error');
    });
    const res = await request(app).get('/api/launches');
    expect(res.status).toBe(500);
  });
});
```

