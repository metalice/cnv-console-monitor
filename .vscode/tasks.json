{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Install All",
      "type": "shell",
      "command": "npm install",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "close": true
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Dev: Server",
      "type": "shell",
      "command": "npm run dev:server",
      "group": "none",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      },
      "problemMatcher": [],
      "dependsOn": ["Install All"],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Dev: Client",
      "type": "shell",
      "command": "npm run dev:client",
      "group": "none",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "dev"
      },
      "problemMatcher": [],
      "dependsOn": ["Install All"],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Dev: All",
      "dependsOn": ["Dev: Server", "Dev: Client"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Build All",
      "type": "shell",
      "command": "npm run build",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Typecheck",
      "type": "shell",
      "command": "npm run typecheck",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "npm run test",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Poll (one-time)",
      "type": "shell",
      "command": "npm run poll",
      "group": "none",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
