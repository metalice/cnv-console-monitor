apiVersion: v1
kind: Secret
metadata:
  name: cnv-ui-monitor-secrets
  labels:
    app: cnv-ui-monitor
type: Opaque
stringData:
  POSTGRES_PASSWORD: "<choose-a-strong-password>"
  DATABASE_URL: "postgresql://cnv_monitor:<same-password>@postgresql:5432/cnv_monitor"
  OAUTH_COOKIE_SECRET: "<generate-with-openssl-rand-base64-32>"
  PP_CLIENT_ID: "<product-pages-oidc-client-id>"
  PP_CLIENT_SECRET: "<product-pages-oidc-client-secret>"
  # All other secrets (RP token, Jira token, Slack webhooks, SMTP)
  # are managed via the Settings page UI and stored in PostgreSQL.
